@model Hostel_V.Models.RoomBookingModel

@{
    ViewData["Title"] = "Add Booking";
}



<body>
    <main class="main">
        <!-- Contact Section -->
        <section id="contact" class="contact section">
            <!-- Section Title -->
            <div class="container section-title" data-aos="fade-up">
                <h2>Contact</h2>
                <p>
                    Get in touch with us for any inquiries, bookings, or support—we’re here to help you anytime.
                    Our team is always ready to assist you and ensure a smooth and comfortable hostel experience.
                </p>
            </div><!-- End Section Title -->

            

            <div class="container" data-aos="fade-up" data-aos-delay="100">

                <div class="row gy-4">

                    <div class="col-lg-5">

                        <div class="info-wrap">
                            <div class="info-item d-flex" data-aos="fade-up" data-aos-delay="200">
                                <i class="bi bi-geo-alt flex-shrink-0"></i>
                                <div>
                                    <h3>Address</h3>
                                    <p>k.k.v hole Rajkot ,Gujrat</p>
                                </div>
                            </div><!-- End Info Item -->

                            <div class="info-item d-flex" data-aos="fade-up" data-aos-delay="300">
                                <i class="bi bi-telephone flex-shrink-0"></i>
                                <div>
                                    <h3>Call Us</h3>
                                    <p>+91 72111 37408</p>
                                </div>
                            </div><!-- End Info Item -->

                            <div class="info-item d-flex" data-aos="fade-up" data-aos-delay="400">
                                <i class="bi bi-envelope flex-shrink-0"></i>
                                <div>
                                    <h3>Email Us</h3>
                                    <p>hostel-v@gmail.com</p>
                                </div>
                            </div><!-- End Info Item -->

                            <iframe src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d48389.78314118045!2d-74.006138!3d40.710059!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c25a22a3bda30d%3A0xb89d1fe6bc499443!2sDowntown%20Conference%20Center!5e0!3m2!1sen!2sus!4v1676961268712!5m2!1sen!2sus" frameborder="0" style="border:0; width: 100%; height: 270px;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                        </div>
                    </div>

                    <div class="col-lg-7">

                        <div class="info-wrap">
                            <div class="card-header bg-success text-white text-center py-3">
                              
                                <h4 class="mb-0">Room Booking</h4>
                                <!-- BACK BUTTON -->

                            </div>
                           <br />

                            @if (ViewBag.Message != null)
                            {
                                <div class="modal fade show" id="successModal" style="display:block;" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <div class="modal-header bg-success text-white">
                                                <h5 class="modal-title">Success</h5>
                                            </div>
                                            <div class="modal-body">
                                                @ViewBag.Message
                                            </div>
                                            <div class="modal-footer">
                                                <a class="nav-link active" asp-area=""
                                                   asp-controller="Dashboard" asp-action="Index">Ok</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                            <form asp-action="Add" method="post">
                                @Html.AntiForgeryToken()

                                <!-- Validation Summary -->
                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                                <div class="row g-3">

                                    <!-- Guest Name -->
                                    <div class="col-md-6">
                                        <label asp-for="Guest_Name" class="form-label"></label>
                                        <input asp-for="Guest_Name" class="form-control" />
                                        <span asp-validation-for="Guest_Name" class="text-danger"></span>
                                    </div>

                                    <!-- Mobile -->
                                    <div class="col-md-6">
                                        <label asp-for="Mobile_No" class="form-label"></label>
                                        <input asp-for="Mobile_No" class="form-control" />
                                        <span asp-validation-for="Mobile_No" class="text-danger"></span>
                                    </div>

                                  
                                    <!-- Room Number -->
                                    <div class="col-md-6">
                                        <label asp-for="Room_Number" class="form-label"></label>
                                        <select asp-for="Room_Number" class="form-control">
                                            <option value="">-- Select Room --</option>
                                            @for (int i = 101; i <= 120; i++)
                                            {
                                                <option value="A-@i">A-@i</option>
                                            }
                                        </select>
                                        <span asp-validation-for="Room_Number" class="text-danger"></span>
                                    </div>

                                    <!-- Booking Date -->
                                    <div class="col-md-6">
                                        <label asp-for="Booking_Date" class="form-label"></label>
                                        <input asp-for="Booking_Date" type="date" class="form-control" />
                                        <span asp-validation-for="Booking_Date" class="text-danger"></span>
                                    </div>

                                    <!-- Address -->
                                    <div class="col-md-6">
                                        <label asp-for="Address" class="form-label"></label>
                                        <input asp-for="Address" class="form-control" />
                                        <span asp-validation-for="Address" class="text-danger"></span>
                                    </div>

                                    <!-- Status -->
                                    <div class="col-md-6">
                                        <label asp-for="Booking_Status" class="form-label"></label>
                                        <select asp-for="Booking_Status" class="form-select">
                                            <option>Booked</option>
                                            <option>CheckedIn</option>
                                            <option>CheckedOut</option>
                                            <option>Cancelled</option>
                                        </select>
                                        <span asp-validation-for="Booking_Status" class="text-danger"></span>
                                    </div>

                                </div>

                                <!-- BUTTONS -->
                                <div class="mt-4 text-end">
                                    <a asp-controller="RoomBooking" asp-action="Add" class="btn btn-secondary me-2">Cancel</a>
                                    <button type="submit" class="btn btn-success">
                                        Save Booking
                                    </button>
                                </div>

                            </form>

                        </div>
                    </div><!-- End Contact Form -->

                  

                </div>

            </div>

        </section><!-- /Contact Section -->

    </main>
</body>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
