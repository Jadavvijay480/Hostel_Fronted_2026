@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<body>
<main class="main">

    <!-- Hero Section -->
    <section id="hero" class="hero section accent-background">

        <div id="hero-carousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="5000">

            <div class="carousel-item active">
                <img src="~/assets/img/hero-carousel/image-1.png" alt="">
               
                <div class="carousel-container">
                    <h2>Welcome to Hostel-V</h2>
                    <p>
                        Welcome to Hostel-V, your trusted platform for easy and convenient hostel room booking.
                        Explore available rooms, check details, and secure your stay with a simple and user-friendly experience.
                    </p>
                    @* <a href="#featured-services" class="btn-get-started">Get Started</a> *@
                </div>
            </div><!-- End Carousel Item -->

            <div class="carousel-item">
                <img src="~/assets/img/hero-carousel/image-2.jpg" alt="">
               
                <div class="carousel-container">
                    <h2>Our Facility For Hostel</h2>
                    <p>
                        Comfortable and well-furnished rooms with 24/7 security and high-speed Wi-Fi for a safe and connected stay.
                        Enjoy clean facilities, regular housekeeping, and essential amenities designed for student convenience.
                    </p>
                    @* <a href="#featured-services" class="btn-get-started">Get Started</a> *@
                </div>
            </div><!-- End Carousel Item -->

            <div class="carousel-item">
                <img src="~/assets/img/hero-carousel/image-3.jpg" alt="">
              
                <div class="carousel-container">
                    <h2>Hostel Description</h2>
                    <p>
                        Hostel-V – a trusted name in student accommodation, offering comfort, safety, and convenience.
                        Dedicated to providing a modern and reliable living experience for students away from home.
                    </p>
                    @* <a href="#featured-services" class="btn-get-started">Get Started</a> *@
                </div>
            </div><!-- End Carousel Item -->

            <a class="carousel-control-prev" href="#hero-carousel" role="button" data-bs-slide="prev">
                <span class="carousel-control-prev-icon bi bi-chevron-left" aria-hidden="true"></span>
            </a>

            <a class="carousel-control-next" href="#hero-carousel" role="button" data-bs-slide="next">
                <span class="carousel-control-next-icon bi bi-chevron-right" aria-hidden="true"></span>
            </a>

            <ol class="carousel-indicators"></ol>

        </div>

    </section><!-- /Hero Section -->
    <!-- Featured Services Section -->
    <section id="featured-services" class="featured-services section light-background">

        <div class="container">

            <div class="row gy-4">

                <div class="col-xl-3 col-md-6 d-flex" data-aos="fade-up" data-aos-delay="100">
                    <div class="service-item position-relative">
                        <div class="icon"><i class="bi bi-house-door icon"></i></div>
                        <h4><a href="" class="stretched-link">Comfortable Rooms</a></h4>
                        <p>Well-furnished and spacious rooms designed for a comfortable and peaceful stay.</p>
                    </div>
                </div><!-- End Service Item -->

                <div class="col-xl-3 col-md-6 d-flex" data-aos="fade-up" data-aos-delay="200">
                    <div class="service-item position-relative">
                        <div class="icon"><i class="bi bi-wifi icon"></i></div>
                        <h4><a href="" class="stretched-link">Free Wi-Fi</a></h4>
                        <p>High-speed internet access available 24/7 to support your study and entertainment needs.</p>
                    </div>
                </div><!-- End Service Item -->

                <div class="col-xl-3 col-md-6 d-flex" data-aos="fade-up" data-aos-delay="300">
                    <div class="service-item position-relative">
                        <div class="icon"><i class="bi bi-shield-check icon"></i></div>
                        <h4><a href="" class="stretched-link">24/7 Security</a></h4>
                        <p>Advanced security system with CCTV and staff to ensure a safe living environment.</p>
                    </div>
                </div><!-- End Service Item -->

                <div class="col-xl-3 col-md-6 d-flex" data-aos="fade-up" data-aos-delay="400">
                    <div class="service-item position-relative">
                        <div class="icon"><i class="bi bi-brush icon"></i></div>
                        <h4><a href="" class="stretched-link">Clean & Hygienic</a></h4>
                        <p>Regular cleaning and maintenance to provide a hygienic and healthy atmosphere.</p>
                    </div>
                </div><!-- End Service Item -->

            </div>

        </div>

    </section>
    <!-- /Featured Services Section -->
</main>
</body>